# ─────────────────────────────────────────────────────────────────
# Cleantech Quant API — Environment Variables
# Copy to .env and fill in your values before starting.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────
APP_NAME="NH3 Intelligence API"
DEBUG=false

# Generate with: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_STRING
JWT_SECRET=REPLACE_WITH_ANOTHER_64_CHAR_RANDOM_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

API_KEY_PREFIX=ctq_

# ── Database ─────────────────────────────────────────────────────
# Local dev (matches docker-compose.yml):
DATABASE_URL=postgresql+asyncpg://ctquser:ctqpass@postgres:5432/cleantech_api

# Production (AWS RDS example):
# DATABASE_URL=postgresql+asyncpg://ctquser:STRONG_PASSWORD@your-rds-endpoint.rds.amazonaws.com:5432/cleantech_api

# ── Redis ────────────────────────────────────────────────────────
# Local dev:
REDIS_URL=redis://redis:6379

# Production (ElastiCache / Upstash):
# REDIS_URL=rediss://:TOKEN@your-upstash-endpoint.upstash.io:6379

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list — add your frontend domain
ALLOWED_ORIGINS=["http://localhost:3000","https://app.cleantechquant.io"]
ALLOWED_HOSTS=["*"]

# ── Stripe (payments) ────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET

# Stripe Price IDs (create in Stripe dashboard → Products)
STRIPE_ANALYST_PRICE_ID=price_REPLACE
STRIPE_ENTERPRISE_PRICE_ID=price_REPLACE

# ── Email (SendGrid) ─────────────────────────────────────────────
# Get from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.REPLACE_WITH_YOUR_SENDGRID_API_KEY
FROM_EMAIL=alerts@cleantechquant.io

# ── AWS S3 (report storage) ──────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA_REPLACE
AWS_SECRET_ACCESS_KEY=REPLACE
AWS_S3_BUCKET=cleantech-quant-reports
AWS_REGION=us-east-1

# ── Scraper ──────────────────────────────────────────────────────
SCRAPER_INTERVAL_HOURS=6
# Email shown to Crossref polite pool (required for API access)
USER_AGENT=CleanTechQuantResearch/1.0 (api@cleantechquant.io)

# ── Monitoring (optional) ────────────────────────────────────────
# SENTRY_DSN=https://YOUR_KEY@sentry.io/YOUR_PROJECT_ID

# ── Plan pricing in Stripe cents ────────────────────────────────
# These must match your Stripe products
# analyst = $499/mo = 49900 cents
# enterprise = $1500/mo = 150000 cents
